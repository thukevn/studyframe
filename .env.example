# ========================================
# StudyFrame - Environment Variables
# Copy this file to .env and fill in values
# ========================================

# --- Google Gemini AI (Backend reasoning & image planning) ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Drive (Video storage) ---
# Get from: https://console.cloud.google.com/
# Enable Google Drive API, create OAuth2 credentials, download as JSON
GOOGLE_DRIVE_CREDENTIALS_JSON=path/to/credentials.json
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# --- Notion (Study session logging) ---
# Get from: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# --- Backend Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Chrome Agent (Puppeteer) ---
# Path to your Chrome/Chromium executable
CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Set to 'true' to run browser headlessly (no window), 'false' to see it
HEADLESS=false
# How many seconds to wait between Meta AI interactions (avoid rate limits)
AGENT_DELAY_MS=3000

# --- TTS / Audio ---
# Voice speed for narration (default: 1.0)
TTS_SPEED=1.0
# Language code for gTTS (default: en)
TTS_LANG=en

# --- Output Paths ---
# Where generated job files (images, audio, video) are stored
OUTPUT_DIR=./output
